# Database (MySQL)
# Example format:
# mysql://USER:PASSWORD@HOST:3306/DB_NAME?charset=utf8mb4
DATABASE_URL="mysql://app_user:app_password@localhost:3306/placement_db?charset=utf8mb4"

# NextAuth
NEXTAUTH_SECRET="replace-with-a-secure-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Optional bootstrap admin credentials for one-time seeding.
# Never use default values in production.
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""
